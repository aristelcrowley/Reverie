{"id":1,"name":"EV001","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["sora_2",2,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Another morning in Firsta..."]},{"code":101,"indent":0,"parameters":["",0,0,2,"Other"]},{"code":401,"indent":0,"parameters":["Hey, Sora! Come over here for a sec!"]},{"code":101,"indent":0,"parameters":["sora_1",6,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Huh? Good morning, sir. What is it?"]},{"code":101,"indent":0,"parameters":["",0,0,2,"Other"]},{"code":401,"indent":0,"parameters":["Can you take this mine waste and dump it by the"]},{"code":401,"indent":0,"parameters":["coast for me?"]},{"code":101,"indent":0,"parameters":["sora_2",2,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Again...? But sir, I just did that yesterday."]},{"code":101,"indent":0,"parameters":["",0,0,2,"Other"]},{"code":401,"indent":0,"parameters":["Come on, you're the only one who can do it! You've"]},{"code":401,"indent":0,"parameters":["got that weird poison immunity, right? If I touch"]},{"code":401,"indent":0,"parameters":["this stuff, I'll get sick!"]},{"code":101,"indent":0,"parameters":["sora_1",6,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["That's not really a good reason..."]},{"code":101,"indent":0,"parameters":["sora_2",2,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["..."]},{"code":101,"indent":0,"parameters":["sora_1",6,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Fine. I'll do it."]},{"code":101,"indent":0,"parameters":["",0,0,2,"Other"]},{"code":401,"indent":0,"parameters":["Good boy! Thanks a lot!"]},{"code":101,"indent":0,"parameters":["sora_1",7,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["I'm sorry, beautiful beach..."]},{"code":101,"indent":0,"parameters":["sora_2",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["I really don't want to throw this smelly stuff here."]},{"code":101,"indent":0,"parameters":["sora_2",2,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["But I guess I have no choice..."]},{"code":101,"indent":0,"parameters":["sora_2",2,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Ugh... My hands feel gross now."]},{"code":101,"indent":0,"parameters":["sora_2",4,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["I'm so tired of doing people's chores all the time."]},{"code":101,"indent":0,"parameters":["sora_2",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["I should go see what Zuko is doing."]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["BOO!"]},{"code":101,"indent":0,"parameters":["sora_1",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Whoa!"]},{"code":101,"indent":0,"parameters":["zuko_2",4,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["HAHA! Gotcha! You should have seen your face, Sora!"]},{"code":101,"indent":0,"parameters":["sora_2",2,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Zuko... don't do that. It's not funny."]},{"code":101,"indent":0,"parameters":["zuko_2",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["Aw, come on! It was a little funny! Anyway, what"]},{"code":401,"indent":0,"parameters":["took you so long?"]},{"code":101,"indent":0,"parameters":["sora_1",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["I had to carry something for the villagers. Again."]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["Let me guess. Another dirty, smelly job nobody else"]},{"code":401,"indent":0,"parameters":["wanted to do?"]},{"code":101,"indent":0,"parameters":["sora_2",2,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Yeah..."]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["Classic Firsta! They always give you the worst stuff"]},{"code":401,"indent":0,"parameters":["just because you don't get poisoned."]},{"code":101,"indent":0,"parameters":["sora_1",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Were you just hiding behind this tree all morning?"]},{"code":101,"indent":0,"parameters":["zuko_1",2,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["Pssh, NO! I was... resting! Yeah! It's called"]},{"code":401,"indent":0,"parameters":["conserving my awesome energy!"]},{"code":101,"indent":0,"parameters":["sora_1",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["That sounds exactly like hiding."]},{"code":101,"indent":0,"parameters":["zuko_2",2,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["It is NOT the same! Look, I'm just... thinking."]},{"code":101,"indent":0,"parameters":["sora_2",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["About what?"]},{"code":101,"indent":0,"parameters":["zuko_2",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["About how this place feels too quiet. It's weird!"]},{"code":401,"indent":0,"parameters":["It's like everyone here is pretending nothing bad"]},{"code":401,"indent":0,"parameters":["will ever happen to us."]},{"code":101,"indent":0,"parameters":["sora_1",6,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Quiet is good, Zuko. We like quiet."]},{"code":101,"indent":0,"parameters":["zuko_2",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["No, it's not! What about the \\C[4]Elementa\\C[0]? And"]},{"code":401,"indent":0,"parameters":["the \\C[2]Elementor\\C[0]!?"]},{"code":101,"indent":0,"parameters":["sora_1",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["You're still talking about those? The adults say"]},{"code":401,"indent":0,"parameters":["they're just scary stories to make us behave."]},{"code":101,"indent":0,"parameters":["zuko_2",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["Adults say a lot of silly things! You don't actually"]},{"code":401,"indent":0,"parameters":["believe them, do you?"]},{"code":101,"indent":0,"parameters":["sora_2",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Not really..."]},{"code":101,"indent":0,"parameters":["zuko_1",6,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["Good! Because \\C[2]Elementor\\C[0] is totally real! I"]},{"code":401,"indent":0,"parameters":["can feel it in my bones!"]},{"code":101,"indent":0,"parameters":["sora_1",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["You sound very sure."]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["I AM sure! Look, if they come here, we're toast!"]},{"code":401,"indent":0,"parameters":["Squashed! Gone!"]},{"code":101,"indent":0,"parameters":["sora_2",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Then what are they?"]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["They're big, scary, bad things! And we have to find"]},{"code":401,"indent":0,"parameters":["Shii!"]},{"code":101,"indent":0,"parameters":["sora_2",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Shii? What's a Shii?"]},{"code":101,"indent":0,"parameters":["zuko_2",2,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["It's, like... the light inside you! It makes you"]},{"code":401,"indent":0,"parameters":["super strong and brave so the bad things can't get"]},{"code":401,"indent":0,"parameters":["you!"]},{"code":101,"indent":0,"parameters":["sora_1",3,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["That sounds way more made-up than the"]},{"code":401,"indent":0,"parameters":["\\C[2]Elementor\\C[0]..."]},{"code":101,"indent":0,"parameters":["zuko_2",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["I am telling the truth! If we find our Shii, maybe"]},{"code":401,"indent":0,"parameters":["we won't feel so scared when everything goes bad!"]},{"code":101,"indent":0,"parameters":["sora_2",2,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["..."]},{"code":101,"indent":0,"parameters":["sora_2",4,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Well... I am tired of being told what to do all the"]},{"code":401,"indent":0,"parameters":["time. Dumping trash isn't fun."]},{"code":101,"indent":0,"parameters":["zuko_1",2,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["YES! That's the spirit! So you're coming with me!?"]},{"code":101,"indent":0,"parameters":["sora_2",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Where to?"]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["We need to get Ann and Gin! Let's go ask Ann first!"]},{"code":401,"indent":0,"parameters":["I bet she's staring at the boring sea again!"]},{"code":101,"indent":0,"parameters":["sora_1",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["You already decided this by yourself, didn't you?"]},{"code":101,"indent":0,"parameters":["zuko_1",2,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["Maybe! Come on, let's go! WOO-HOO!!"]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["HEEEEY, ANN!!"]},{"code":101,"indent":0,"parameters":["ann_1",0,0,2,"Ann"]},{"code":401,"indent":0,"parameters":["Ugh. I heard you the first time, Zuko. You don't"]},{"code":401,"indent":0,"parameters":["have to yell."]},{"code":101,"indent":0,"parameters":["sora_1",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Hi, Ann. You're looking at the sea again."]},{"code":101,"indent":0,"parameters":["ann_2",0,0,2,"Ann"]},{"code":401,"indent":0,"parameters":["Because it's quiet here. At least until Zuko showed"]},{"code":401,"indent":0,"parameters":["up."]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["Hey! I'm not that loud! Besides, staring at water is"]},{"code":401,"indent":0,"parameters":["super boring!"]},{"code":101,"indent":0,"parameters