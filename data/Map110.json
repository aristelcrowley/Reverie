{"id":1,"name":"EV001","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":101,"indent":0,"parameters":["zuko_2",1,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["\\FX<FC, shake>GUYS! It's not just"]},{"code":401,"indent":0,"parameters":["\\C[4]Elementa\\C[0]... The big one..."]},{"code":401,"indent":0,"parameters":["\\C[2]Elementor\\C[0] is here too!! RUNNN!!\\RX"]},{"code":101,"indent":0,"parameters":["sora_1",5,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["That thing too?!"]},{"code":101,"indent":0,"parameters":["zuko_2",1,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["\\FX<FC, shake>YES, THAT THING TOO!! AAAAAAA!!\\RX"]},{"code":101,"indent":0,"parameters":["ann_1",0,0,2,"Ann"]},{"code":401,"indent":0,"parameters":["LESS TALKING! MORE RUNNING!!"]},{"code":101,"indent":0,"parameters":["gin_1",5,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["\\FX<FC, shake>W-WHY IS IT COMING THIS WAY?!\\RX"]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["BECAUSE YOU'RE STANDING IN FRONT OF IT, GENIUS!"]},{"code":101,"indent":0,"parameters":["gin_1",3,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["T-THAT IS NOT HELPFUL AT ALL!!"]},{"code":101,"indent":0,"parameters":["sora_1",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Get behind me, guys!"]},{"code":101,"indent":0,"parameters":["ann_1",0,0,2,"Ann"]},{"code":401,"indent":0,"parameters":["Sora, don't act brave all of a sudden! It's"]},{"code":401,"indent":0,"parameters":["dangerous!"]},{"code":101,"indent":0,"parameters":["sora_2",2,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["I-I'm trying...!"]},{"code":101,"indent":0,"parameters":["gin_1",5,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["I HATE THIS. I HATE THIS. I HATE THIS."]},{"code":101,"indent":0,"parameters":["zuko_1",3,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["SHUT UP AND SWING SOMETHING!! WHACK IT!!"]},{"code":101,"indent":0,"parameters":["ann_1",4,0,2,"Ann"]},{"code":401,"indent":0,"parameters":["Stop panicking and watch your step, you idiots!"]},{"code":101,"indent":0,"parameters":["sora_1",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["W-We can do this!"]},{"code":101,"indent":0,"parameters":["gin_1",0,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["I DO NOT FEEL LIKE WE CAN DO THIS!! THE PROBABILITY"]},{"code":401,"indent":0,"parameters":["OF SURVIVAL IS ZERO!!"]},{"code":101,"indent":0,"parameters":["gin_2",0,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["I-Is it gone...?"]},{"code":101,"indent":0,"parameters":["ann_1",0,0,2,"Ann"]},{"code":401,"indent":0,"parameters":["Not gone. Just down. Don't let your guard down."]},{"code":101,"indent":0,"parameters":["zuko_1",5,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["THEN LET'S RUN BEFORE IT GETS BACK UP!!"]},{"code":101,"indent":0,"parameters":["sora_1",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Everyone, stay close and follow me!"]},{"code":101,"indent":0,"parameters":["gin_1",0,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["I CHANGED MY MIND! I CHANGED MY MIND!"]},{"code":101,"indent":0,"parameters":["zuko_2",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["ABOUT WHAT?!"]},{"code":101,"indent":0,"parameters":["gin_1",0,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["ABOUT SHII! I WANT TO FIND SHII NOW!"]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["A LITTLE TOO LATE FOR THAT, BUDDY!"]},{"code":101,"indent":0,"parameters":["gin_2",2,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["I KNOW! I KNOW THAT NOW!! PLEASE DON'T LEAVE ME!!"]},{"code":101,"indent":0,"parameters":["ann_2",0,0,2,"Ann"]},{"code":401,"indent":0,"parameters":["You were really loud earlier for someone who wanted"]},{"code":401,"indent":0,"parameters":["to stay behind!"]},{"code":101,"indent":0,"parameters":["gin_1",0,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["I WAS TRYING TO BE REASONABLE! IT WAS LOGICAL!"]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["YOU WERE TRYING TO BE ANNOYING!"]},{"code":101,"indent":0,"parameters":["gin_1",0,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["THAT'S NOT FAIR!!"]},{"code":101,"indent":0,"parameters":["sora_1",3,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Stop fighting! Keep going!"]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["Hey, Sora!"]},{"code":101,"indent":0,"parameters":["sora_2",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["What is it now?!"]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["You're not bad at this!"]},{"code":101,"indent":0,"parameters":["sora_2",2,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["At... running away for our lives?!"]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["Nah. At leading us!"]},{"code":101,"indent":0,"parameters":["sora_2",2,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Don't... don't joke around right now!"]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["I'm totally serious!"]},{"code":101,"indent":0,"parameters":["ann_1",0,0,2,"Ann"]},{"code":401,"indent":0,"parameters":["He actually is, weirdly enough."]},{"code":101,"indent":0,"parameters":["gin_1",5,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["CAN YOU GUYS STOP HAVING A NICE MOMENT AND RUN"]},{"code":401,"indent":0,"parameters":["FASTER?! PLEASE?!"]},{"code":101,"indent":0,"parameters":["sora_2",2,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Oh no... It's locked."]},{"code":101,"indent":0,"parameters":["zuko_1",3,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["SERIOUSLY?! OF COURSE IT IS!"]},{"code":101,"indent":0,"parameters":["gin_2",2,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["You're kidding. You have to be kidding me. T-This is"]},{"code":401,"indent":0,"parameters":["the end..."]},{"code":101,"indent":0,"parameters":["ann_1",0,0,2,"Ann"]},{"code":401,"indent":0,"parameters":["Don't panic! It looks like we just need a key."]},{"code":101,"indent":0,"parameters":["sora_2",2,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["A key... right. Let's find it, quickly!"]},{"code":101,"indent":0,"parameters":["ann_1",0,0,2,"Ann"]},{"code":401,"indent":0,"parameters":["The bridge! It broke!"]},{"code":101,"indent":0,"parameters":["zuko_1",6,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["Okay! New plan! We do NOT go that way!"]},{"code":101,"indent":0,"parameters":["gin_1",0,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["That was our way back! That was very important"]},{"code":401,"indent":0,"parameters":["infrastructure!"]},{"code":101,"indent":0,"parameters":["sora_1",0,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["Then we keep moving forward. There has to be another"]},{"code":401,"indent":0,"parameters":["path."]},{"code":101,"indent":0,"parameters":["",0,0,2,"Other"]},{"code":401,"indent":0,"parameters":["The coast road! Go to the coast road!"]},{"code":101,"indent":0,"parameters":["ann_1",0,0,2,"Ann"]},{"code":401,"indent":0,"parameters":["You heard him. Move!"]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["Race you to not dying!"]},{"code":101,"indent":0,"parameters":["ann_1",0,0,2,"Ann"]},{"code":401,"indent":0,"parameters":["Zuko!"]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["Right, right! Serious running!"]},{"code":101,"indent":0,"parameters":["sora_1",3,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["The path stops here..."]},{"code":101,"indent":0,"parameters":["ann_1",5,0,2,"Ann"]},{"code":401,"indent":0,"parameters":["No. No, no. There has to be another way."]},{"code":101,"indent":0,"parameters":["zuko_2",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["Maybe we can jump over it!"]},{"code":101,"indent":0,"parameters":["ann_1",0,0,2,"Ann"]},{"code":401,"indent":0,"parameters":["That is the sea, Zuko. You cannot jump over the sea."]},{"code":101,"indent":0,"parameters":["zuko_2",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["I said maybe!"]},{"code":101,"indent":0,"parameters":["gin_1",0,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["I-I can swim. A little."]},{"code":101,"indent":0,"parameters":["zuko_2",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["WAIT. YOU CAN SWIM?!"]},{"code":101,"indent":0,"parameters":["gin_2",0,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["Why are you yelling like I grew wings?!"]},{"code":101,"indent":0,"parameters":["ann_2",0,0,2,"Ann"]},{"code":401,"indent":0,"parameters":["Gin, can you get across?"]},{"code":101,"indent":0,"parameters":["gin_1",3,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["Maybe... if the current is not too rude."]},{"code":101,"indent":0,"parameters":["sora_1",7,0,2,"Sora"]},{"code":401,"indent":0,"parameters":["We will stay together. You do not have to do it"]},{"code":401,"indent":0,"parameters":["alone."]},{"code":101,"indent":0,"parameters":["gin_1",1,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["That sounds nice, but it does not make the water"]},{"code":401,"indent":0,"parameters":["less wet!"]},{"code":101,"indent":0,"parameters":["zuko_1",0,0,2,"Zuko"]},{"code":401,"indent":0,"parameters":["Come on, Gin! This is your big hero moment!"]},{"code":101,"indent":0,"parameters":["gin_1",5,0,2,"Gin"]},{"code":401,"indent":0,"parameters":["\\FX<FC, shake>I do not want a big hero moment! I"]},{"code":401,"indent":0,"parameters