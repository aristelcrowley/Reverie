{
  "map": "Map109",
  "events": [
    {
      "id": "EV001",
      "page": 0,
      "commands": [
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "exhausted",
          "text": "Zuko... Ann... Gin..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "Where did everyone go?"
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "exhausted",
          "text": "My body feels so heavy..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "No. I can still walk."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "There is a house by the road..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "Excuse me..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "A child? Out here?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Father, he looks hurt."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Come in, boy. Do not stand at the door."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "I am sorry. I did not mean to intrude."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "You look like you are one step away from collapsing."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "I can still move."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "That is not the same as being fine. Sit."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Eat with us. Drink a little too."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "I do not want to trouble you."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Food is meant to be shared before it goes cold."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "And Father cooks better when someone praises him."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Do not listen to that part."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "relieved",
          "text": "Thank you."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "...Huh?"
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "My strength came back so quickly."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "Was that mementos in the food?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Mementos?"
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "Never mind. Maybe I was just hungry."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "What is at the end of this road?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "A village."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Or what is left of one."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "What happened there?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Waste from the factory poisoned it. The ground, the river, the homes."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "No one should live there anymore."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Do not go that way if you value your life."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "Is everyone gone?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "One man made it out."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "He was barely alive when I found him near the road."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I brought him here and did what I could."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "Where is he?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "In the last room."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Let him rest if he cannot answer you."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "I need to know what happened in that village."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "Sir? Can you hear me?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Who... are you?"
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "My name is Sora. I need to ask about your village."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "My village..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "A few days ago, I heard something like an explosion from the factory."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I went there to check."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Inside... I saw a giant creature."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "It was not an animal. Not a person. Just something wrong."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "\\C[2]Elementor\\C[0]..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I ran."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "When I reached the village, factory waste had already leaked into the river."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "The water carried it everywhere."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Before I left the factory area, I locked the gate."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I thought it would keep that huge thing inside."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "But outside, the animals around the village had already changed."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "They became monsters. Elementa made of poison and waste."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I ran home for my wife and child."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "We tried to leave."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "The monsters attacked us before we reached the road."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "My wife... my child..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "They died there."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "I am sorry."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I survived. That is all I managed to do."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "I need the key to the factory."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I will not hand it over for nothing."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "What do you want?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "There is a family photo in my house."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Bring it to me."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I want to see them one last time."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "I will bring it back."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "And listen carefully."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "The factory is dark. Too dark to search with your bare eyes."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Find a light before you enter."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "A photo and a light. I understand."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "The village air is green..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "The fog is so thick I can barely see the road."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "Waste-type Elementa are roaming here."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "I have to search the houses carefully."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Do not come closer. I am not one of them. I am not bad. I still know my own hands."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "I am not here to hurt you. I only want to ask something."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "Do you know the stranger's house? Or where I can find a light?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "House? Stranger? The walls keep changing names. I do not trust walls anymore."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "But the small sun fell into the stone's narrow mouth."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "A crack under the hill swallowed it. Not a door. Not a throat. Something between."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "A narrow mouth under the hill..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "My shiny thing is there too. It slipped away and forgot my pocket."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Bring it back, and maybe my head will stop knocking."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "All right. I will look for it."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "This must be the place he meant."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "The gap is very narrow. I can barely fit my arm through."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "If Ann were here, she would tell me this is a terrible idea."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "relieved",
          "text": "Got it. The light still works."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Can you fly?"
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "Huh?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "The cloud up there stole something from me. If you fly, take it back."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "I cannot fly."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Then walk softly. The ground is listening with its teeth."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "relieved",
          "text": "...I will be careful."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "There is an item by the river."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "If Gin were here, we could probably get it."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "But the river has turned poisonous. I cannot risk it alone."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "This house..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "It must belong to the man from the road."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "The photo is here."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "I should take it back to him."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "Wait..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "The plants near the road are withered."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "panicking",
          "text": "The river is green here too."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "panicking",
          "text": "No... The waste reached the house."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "panicking",
          "text": "Sir! Are you there?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "You... came back..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "What happened to you and your child?"
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "The food... the water..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "It was already contaminated."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "I am sorry. I thought this place was still safe."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "panicking",
          "text": "Do not apologize. You were trying to help me."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "That is why you recovered so quickly."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "The poison... the mementos in it... it was not normal."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "So that was why..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Go to him."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "You brought what he asked for, did you not?"
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "Yes."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "Then let him see his family."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "Please hold on."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "He is not breathing..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "The factory key is in his hand."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "I brought your photo back."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "I will leave it with you."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "Rest in peace."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "I hope you can meet your wife and child again somewhere gentle."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "I will take the key now."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "I still have to find my Elementor and Shii."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "The factory should be deeper inside the village."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "More Elementa are blocking the road."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "This is the factory gate."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "The key fits..."
        },
        {
          "type": "dialogue",
          "actor": "other",
          "expression": "default",
          "text": "..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "panicking",
          "text": "The Elementor!"
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "I cannot beat that thing like this."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "I only need to survive until I can escape."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "exhausted",
          "text": "Just keep moving..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "panicking",
          "text": "The escape chance is almost there!"
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "\\FX<FC, hard shake>NOW!\\RX"
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "exhausted",
          "text": "I made it out..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "panicking",
          "text": "The factory is collapsing!"
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "The entrance is blocked by rubble."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "There has to be another way out."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "confused",
          "text": "An underground passage..."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "It is like a maze under the factory."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "holding_tears",
          "text": "Shii is not here."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "anxious",
          "text": "I can feel it... Shii is far away from this place."
        },
        {
          "type": "dialogue",
          "actor": "sora",
          "expression": "normal",
          "text": "Then I have to keep going."
        }
      ]
    }
  ]
}
